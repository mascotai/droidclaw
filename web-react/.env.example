# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# DroidClaw server URL (Hono backend)
SERVER_URL="http://localhost:8080"

# WebSocket URL for real-time events (used by client)
VITE_WS_URL="ws://localhost:8080"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="DroidClaw <noreply@example.com>"

# Optional: Proxy auth (authentik forward-auth)
TRUST_PROXY_AUTH="false"

# Optional: Better Auth URL
BETTER_AUTH_URL="http://localhost:5173"

# Optional: Internal secret for server communication
INTERNAL_SECRET="your-secret-key"

# Port for production proxy server
PORT=3000
