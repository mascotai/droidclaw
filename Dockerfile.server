FROM oven/bun:1

ARG GIT_SHA=unknown
ENV GIT_SHA=${GIT_SHA}

WORKDIR /app

COPY package.json ./
COPY packages/shared ./packages/shared
COPY server ./server

# Remove "web" workspace entry (web is built separately)
RUN sed -i 's/, "web"//' package.json
RUN bun install

WORKDIR /app/server
EXPOSE 8080
CMD ["bun", "src/index.ts"]
